<%- include('partials/head', { pageTitle: 'Sessions' }) %>
<%- include('partials/nav', { user: user }) %>

<div class="container">
  <div style="margin-bottom: 24px;">
    <h1 style="font-size: 26px; font-weight: 700; color: var(--text-primary); margin-bottom: 6px;">Active Sessions</h1>
    <p style="color: var(--text-secondary); font-size: 14px;">View and revoke your active sessions</p>
  </div>

  <% if (typeof error !== 'undefined' && error) { %>
    <div class="alert alert-error" style="margin-bottom: 20px;"><%= error %></div>
  <% } %>

  <% var queryStr = typeof query !== 'undefined' ? query : {}; %>

  <div class="card" style="padding: 0; overflow: hidden;">
    <div style="padding: 16px 20px; border-bottom: 1px solid var(--border); display: flex; align-items: center; justify-content: space-between;">
      <div>
        <div class="code-tag" style="margin-bottom: 0;">GET /v1/auth/me/sessions</div>
      </div>
      <span style="font-size: 13px; color: var(--text-tertiary);"><%= sessions.length %> session<%= sessions.length !== 1 ? 's' : '' %></span>
    </div>

    <% if (!sessions.length) { %>
      <div style="padding: 40px; text-align: center; color: var(--text-tertiary); font-size: 14px;">
        No sessions found.
      </div>
    <% } else { %>
      <table class="table">
        <thead>
          <tr>
            <th>Session ID</th>
            <th>IP Address</th>
            <th>Device / User Agent</th>
            <th>Last Active</th>
            <th>Created</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% sessions.forEach(function(session) { %>
            <tr>
              <td style="font-family: monospace; font-size: 12px; color: var(--text-tertiary);">
                <%= session.id.slice(0, 12) %>...
              </td>
              <td><%= session.ipAddress || '—' %></td>
              <td style="max-width: 200px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                <%= session.userAgent ? session.userAgent.slice(0, 50) + (session.userAgent.length > 50 ? '...' : '') : '—' %>
              </td>
              <td>
                <% if (session.lastActiveAt) { %>
                  <%= new Date(session.lastActiveAt).toLocaleString('en-US', { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' }) %>
                <% } else { %>—<% } %>
              </td>
              <td>
                <%= new Date(session.createdAt).toLocaleString('en-US', { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' }) %>
              </td>
              <td>
                <form method="POST" action="/sessions/revoke" style="margin: 0;">
                  <input type="hidden" name="sessionId" value="<%= session.id %>" />
                  <button type="submit" class="btn btn-danger btn-sm"
                    onclick="return confirm('Revoke this session?')">
                    Revoke
                  </button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } %>
  </div>
</div>

<%- include('partials/foot') %>
