{
  "expo": {
    "name": "Authon RN Example",
    "slug": "authon-react-native-example",
    "version": "1.0.0",
    "scheme": "authon-example",
    "orientation": "portrait",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "dev.authon.example"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#7c3aed"
      },
      "package": "dev.authon.example"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
