# Authon Examples - Shared Configuration
AUTHON_PROJECT_ID=<your-project-id>
AUTHON_API_URL=https://api.authon.dev
AUTHON_FRONTEND_URL=https://authon.dev

# Vite frontend examples (Vite requires VITE_ prefix)
VITE_AUTHON_PROJECT_ID=<your-project-id>
VITE_AUTHON_API_URL=https://api.authon.dev

# Backend examples only
AUTHON_API_KEY=<your-api-key>
AUTHON_WEBHOOK_SECRET=<your-webhook-secret>

# SvelteKit adapter-node: public origin URL (used for request validation)
SVELTE_ORIGIN=https://your-domain.com
